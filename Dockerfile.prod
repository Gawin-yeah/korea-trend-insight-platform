FROM node:22-bookworm-slim

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY app app
COPY build build
COPY db db
COPY docs docs
COPY next-env.d.ts next-env.d.ts
COPY next.config.ts next.config.ts
COPY package.json package.json
COPY postcss.config.mjs postcss.config.mjs
COPY public public
COPY scripts scripts
COPY src src
COPY tsconfig.json tsconfig.json
COPY vite.config.ts vite.config.ts
COPY worker worker
COPY .openai .openai

RUN npm run build

EXPOSE 3000

CMD ["sh", "-c", "if [ -n \"$DATABASE_URL\" ]; then npm run db:migrate && if [ \"$SEED_ON_BOOT\" = \"true\" ]; then npm run db:seed; fi; fi && npm run start -- --host 0.0.0.0 --port ${PORT:-3000}"]
