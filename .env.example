NODE_ENV=development
PORT=3000
# Demo 模式可留空，应用会自动回退到内置 seed 数据。
DATABASE_URL=
# 完整本地模式可改为：
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/ktrend
NEXT_PUBLIC_APP_URL=http://localhost:3000
YOUTUBE_API_KEY=
YOUTUBE_REGION_CODE=KR
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=
X_API_KEY=
X_API_KEY_SECRET=
X_BEARER_TOKEN=
X_CLIENT_ID=
X_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_SEARCH_DISPLAY=10
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
INGESTION_CRON=0 * * * *
AUTO_REFRESH_INTERVAL_SECONDS=60
NEXT_PUBLIC_AUTO_REFRESH_SECONDS=60
REALTIME_STALE_AFTER_MINUTES=20
DISABLE_REALTIME_AUTOMATION=false
GOOGLE_TRENDS_RSS_URL=https://trends.google.com/trending/rss?geo=KR
SEED_ON_BOOT=true
